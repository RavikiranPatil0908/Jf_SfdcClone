                                                                    $('[id$=totalWPEXP]').trigger('change');
                                                                }

                                                                loadObjDate();


                                                                //To bind easyAutoComplete 
                                                                $('.autoCompleteCompany').keyup(function () {
                                                                    var options = {
                                                                        url: '{!JSENCODE($Resource.CompanyNameJS)}',
