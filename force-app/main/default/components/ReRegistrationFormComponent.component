<apex:component access="global" controller="ReRegistrationFormController" allowDML="true">
    <apex:attribute access="global" name="recordId" type="ID" description="Record Id" assignTo="{!objectId}" />
    <apex:attribute access="global" name="objType" type="String" description="Object Type" assignTo="{!objectType}" />

    <!-- Select2 Select Css -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <!-- Bootstrap DatePicker Css -->
    <link href="{!URLFOR($Resource.NewResource, 'NewResource/assets/css/bootstrap-datetimepicker.min.css')}" rel="stylesheet"/>

    <!-- Wait Me Css -->
    <link href="https://gurayyarar.github.io/AdminBSBMaterialDesign/plugins/waitme/waitMe.css" rel="stylesheet" />

    <!-- Easy AutoComplete Css -->
    <apex:stylesheet value="{!URLFOR($Resource.easyAutoCompleteCSS)}" />

    <script src="https://gurayyarar.github.io/AdminBSBMaterialDesign/js/pages/ui/notifications.js"></script>

    <link href="{!URLFOR($Resource.AdminBSBMaterialDesign, 'AdminBSBMaterialDesign/css/spinner.css')}" rel="stylesheet" />

    <!-- <apex:stylesheet value="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.10/css/select2.min.css" html-integrity="sha256-FdatTf20PQr/rWg+cAKfl6j4/IY3oohFAJ7gVC3M34E="
            html-crossorigin="anonymous" />
    <apex:stylesheet value="{!URLFOR($Resource.NewResourceRevised, 'NewResourceRevised/assets/css/bootstrap.min.css')}" /> -->


    <style>
        .form-group .form-line .form-label {
            top: -10px;
        }

        .zindex4 {
            z-index: 4;
        }

        .btn:not(.btn-link):not(.btn-circle) span.noTop { 
            top: 0px;
            margin-left: 0px;
        }

        .btn-custom {
            border-bottom: 5px solid #285e8e;
            position: relative;
            margin-right: 5px;
        }

        .btn-custom:hover {
            top: 0.5px;
            border-bottom-width: 2.5px;
        }

        .btn-custom:active {
            top: 5px;
            border-bottom: 0;
        }

        .form-control.custom-input  {
            border: #777 solid 1px;
            padding-left: 7px;
        
        }
        .custom-input:hover,
        .custom-input:focus {
            border-color: #007bff; 
            outline:none; 
            box-shadow: 0 0 5px rgba(0, 123, 255, 0.5); 
        }

        .loader-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5); /* Semi-transparent background */
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            pointer-events: all; /* Ensure it blocks interactions */
        }


        .hidden {
            display: none; /* Initially hidden */
        }

        /* Prevent scrolling when loader is visible */
        body.no-scroll {
            overflow: hidden;
            pointer-events: none; /* Prevents clicks on all elements */
        }

        .studentDetails .table-label {
            color: #B8B5B5;
        }

        .blueButton {
            background: #16659c !important;
        }

        .bg-steel-blue {
            background-color: #337ab7;
        }
        .list-group-item-heading{
            font-family:'Roboto', Arial, Tahoma, sans-serif;
        }

    </style>

    <script>
    var checkPercent = 0;
    var objDate = {};
     $(document).ready(function () {
        if ($('[id$=pageUrl]').val() != '') {
            window.location.href = $('[id$=pageUrl]').val();
        }

        $('[id$=strSecToShowHidden]').val();
        if ($('[id$=strSecToShowHidden]').val() === 'msg') {
            $('[id$=reregdialogModal]').modal({
                backdrop: 'static',
                keyboard: false
            }).modal('show');
            $('[id$=reregdialogModal]').removeAttr('aria-hidden');
        }   
     });
    </script>
    
    <!-- Spinner -->
    <div class="loader-overlay hidden">
        <div class="loader">
            <div class="preloader">
                <div class="spinner-layer center">
                    <div class="circle-clipper left">
                        <div class="circle"></div>
                    </div>
                    <div class="circle-clipper right">
                        <div class="circle"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Spinner -->
    <div class="modal fade reregdialogModal" id="reregdialogModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">{!HeaderMessage}</h4>
                </div>
                <div class="modal-body">
                    <apex:repeat value="{!lstMsg}" var="msg">
                        <p>{!msg}</p>
                    </apex:repeat>
                </div>
                <div class="modal-footer">
                    <apex:outputLabel rendered="{!IF((strBtnURL ==null || strBtnURL !='') && eligiableForRereg,true,false)}" style="margin-right: 300px;">
                        <button type="button" class="btn btn-block btn-primary waves-effect" data-dismiss="modal">CHANGE PROGRAM</button>
                    </apex:outputLabel>
                    
                    <apex:commandButton value="Proceed to Pay" styleClass="btn btn-block btn-primary waves-effect" id="btn3" status="processing" action="/apex/{!paymentUrl}"
                        rendered="{! paymentUrl != '' }" />
                    <!-- <apex:commandButton value="Change Program" styleClass="btn btn-block bg-pink waves-effect" id="btn4" status="processing" action="/apex/{!programChangeUrl}"
                        rendered="{! programChangeUrl != '' }" /> -->
                    <!-- <apex:commandButton value="Print Interview Form" styleClass="btn btn-block bg-pink waves-effect" id="btn2" status="processing" action="/apex/{!pdfBtnURL}"
                        rendered="{! pdfBtnURL != '' }" /> -->
                    <apex:commandLink value="OK" styleClass="btn btn-primary" id="btn1" status="processing"
                        action="/apex/{!strBtnURL}" rendered="{! strBtnURL != '' }" />
                    <apex:outputLabel rendered="{!IF((strBtnURL ==null || strBtnURL !='') && !eligiableForRereg,true,false)}">
                        <button class="btn btn-block btn-primary" data-dismiss="modal" >CANCEL</button>
                    </apex:outputLabel>
                    <apex:outputLabel rendered="{!IF((strBtnURL ==null || strBtnURL !='') && eligiableForRereg,true,false)}">
                        <a href="/EnrollmentForm?nav=dashboard" class="btn btn-block btn-primary">CANCEL</a>
                    </apex:outputLabel>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid" id="ReRegInformation">
        <div class="row clearfix">
            <apex:outputPanel >
                <apex:inputHidden id="strSecToShowHidden" value="{!strSecToShow}" />
                <apex:inputHidden id="csRecordId" value="{!csProgram.id}" />
                <apex:inputHidden id="csName" value="{!csProgram.name}" />
                <apex:inputHidden id="isEligible" value="{!csProgram.isEligible}" />
                <apex:inputHidden id="checkCourseraOpted" value="{!objCoursera.checkCourseraOpted}" />
                <apex:inputHidden id="electiveSelected" value="{!electiveSelected}" />
                <apex:inputHidden id="isElectiveNeeded" value="{!isElectiveNeeded}" />
                <apex:inputHidden id="pageUrl" value="{!pgURL}" />
                <apex:inputHidden id="passingYear" value="{!objAccountClone.nm_YearofCollegeCompletion__c}" />
            </apex:outputPanel>
            
            <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="header p-b-0 b-b-n p-t-0 p-l-0 p-r-0">
                        <ul class="nav nav-pills nav-justified thumbnail setup-panel align-center bg-steel-blue">
                            <li class="active" id="InterivewFormTab">
                                <a href="#InterivewForm" style="color: #fff;">
                                    <apex:outputPanel styleClass="list-group-item-heading font-18 font-bold" id="panelHeader">RE-REGISTRATION</apex:outputPanel>
                                </a>
                            </li>
                        </ul>
                    </div>
                
                    <div class="body">
                        <apex:outputPanel rendered="{!eligiableForRereg}">
                            <div class="col-lg-12 col-md-12"><h2 class="card-inside-title">Student Information</h2></div>
                            <div class="cardSectionInfo p-b-25" style="padding-left: 14px;"><strong>Note:</strong> Kindly check Mobile Number, Email Address and choose option for delivery of self Learning Material.</div>
                            <div class="row studentDetails">
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Student No.</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.nm_StudentNo__c}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Semester</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!strRegFor}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Name</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.Name}</span></div>
                                </div>
                                <!-- <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Date of Birth</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.nm_DateOfBirth__c}</span></div>
                                </div> -->
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">AEP Name</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.nm_Centers__r.Name}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Program Name</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!strCurrentProgName}</span></div>
                                </div>
                                
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Address</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.House_No_Name_Shipping_Account__c},{!objAccount.Locality_Name_Shipping__c },{!objAccount.Shipping_Street__c}, {!objAccount.City_Shipping_Account__c }, {!objAccount.State_Province_Shipping__c }, {!objAccount.Zip_Postal_Code_Shipping__c }, {!objAccount.Country_Shipping__c}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Mobile No.</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.PersonMobilePhone}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Email</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span>{!objAccount.PersonEmail}</span></div>
                                </div>
                                <div class="row col-xs-12 col-sm-12 col-md-6 col-lg-6 m-b-0">
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6"><span class="table-label">Do you want to change Your Shipping Address ?</span><span style="color:red;font-style:bold"> *</span></div>
                                    <div class="col-xs-6 col-sm-6 col-md-6 col-lg-6 form-group" style="width:208px;">
                                        <div class="form-line" style="width:208px;">
                                            <apex:selectList value="{!address.addressChoice}" styleClass="form-control notnull" multiselect="false" size="1" style="width:99%;"
                                                id="slfOption">
                                                <apex:selectOptions value="{!ShippingOption}" />
                                            </apex:selectList>
                                        </div>                                    
                                    </div>
                                </div>
                            </div>
                        </apex:outputPanel>
                        <apex:outputPanel rendered="{!IF(!eligiableForRereg,true,false)}">
                            <img src="/img/chatter/OpenRoad.svg" class="img-responsive" style="display: block;
                                margin-left: auto;
                                margin-right: auto;
                                width: 50%"/>
                        </apex:outputPanel>
                    </div>
                </div>
            </div> 

            <apex:outputPanel rendered="{!eligiableForRereg}">
                <div class="col-xs-12 col-sm-12 col-md-12 col-lg-12">
                    <div class="card">
                        <div class="body">
                            <!-- Error Popup panel -->
                            <apex:outputPanel id="ErrorPopUpPanel">
                                <apex:inputHidden id="message" value="{!message}" />
                                <apex:inputHidden id="strSecToShow" value="{!strSecToShow}" />
                            </apex:outputPanel>
                            <!-- Error Popup panel -->

                            <!-- ------------------------------------------ Address Section Begins Here--------------------------------------------- -->
                            <apex:outputPanel styleClass="addessInformationPanel row" style="display:none;">
                                <h2 class="card-inside-title">Address Details</h2>
                                <!-- ------------------------------------------------Editable Section------------------------------------------------------ -->
                                <apex:outputPanel styleClass="editableSection" style="display: none;">
                                    <apex:actionFunction name="getShipingCountryStateCityFromPostalAPI" action="{!updateAddressDetails}" reRender="txtSCity,txtSState,txtSCountry,postalCodeMessage"
                                        oncomplete="postalCodeStatus();" />
                                    <apex:inputHidden value="{!address.postalCodeMessage}" id="postalCodeMessage" />

                                    <div class="row clearfix">
                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="Pin Code" >
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSPostalCode" value="{!address.postalCode}" styleClass="form-control sAddress addField" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="City">
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSCity" value="{!address.city}" styleClass="form-control sAddress" disabled="true"/>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="State">
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSState" value="{!address.state}" styleClass="form-control sAddress" disabled="true" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row clearfix">
                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="Address line 1">
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSHouseNumber" value="{!address.addressLine1}" styleClass="form-control sAddress" maxlength="30" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="Address line 2">
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSStreet" value="{!address.addressLine2}" styleClass="form-control sAddress" maxlength="35" />
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="Address line 3">
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSLocality" value="{!address.addressLine3}" styleClass="form-control" maxlength="35" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row clearfix">
                                        <div class="col-lg-4 col-md-4 col-sm-12 col-xs-12">
                                            <div class="form-group">
                                                <div class="form-line">
                                                    <apex:outputlabel styleClass="form-label" value="Country">
                                                        <apex:outputText style="color:red;font-style:bold" value=" *" />
                                                    </apex:outputlabel>
                                                    <apex:inputText id="txtSCountry" value="{!address.country}" styleClass="form-control sAddress" disabled="true" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </apex:outputPanel>                                
                            </apex:outputPanel>
                            <!-- ------------------------------------------ Career Service Section Begins Here--------------------------------------------- -->
                            <apex:outputPanel id="CSSectionPanel" style="display:none;">
                                <h2 class="card-inside-title">Career Service</h2>
                                <div class="row clearfix">
                                    <div class="col-md-12">
                                        <div class="form-group required-label">
                                                <div class="col-md-3 col-sm-12">
                                                    <div class="radio">
                                                        <strong>Opt for Career Service <span style="color:red;font-style:bold">*</span></strong>
                                                    </div>
                                                </div>
                                                <div class="col-md-2 col-sm-12">
                                                    <div class="form-check">
                                                        <input type="radio" name="CSPackage" id="CSPackage1" class="form-check-input with-gap iCheckRadio"
                                                            data-mode="1" value="Yes" style="border-color:blue" /><label for="CSPackage1">Yes</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-2 col-sm-12">
                                                    <div class="form-check">
                                                        <input type="radio" name="CSPackage" id="CSPackage2" class="form-check-input with-gap iCheckRadio"
                                                            data-mode="2" value="No" /><label for="CSPackage2">No</label>
                                                    </div>
                                                </div>

                                            <apex:outputPanel styleClass="col-md-12" layout="block" id="CSPackagePanel">
                                                <div class="form-group required-label">
                                                    <label>Choose Career Service Package</label>
                                                    <div class="row" id="CSProgramPanel"></div>
                                                </div>
                                            </apex:outputPanel>
                                        </div>
                                    </div>
                                </div> 
                            </apex:outputPanel>

                            <!-- ------------------------------------------ Coursera Section Begins Here--------------------------------------------- -->
                            <apex:outputPanel id="CourseraSectionPanel" rendered="{!IF(objCoursera.showCoursera && !objCoursera.isCourseraAlreadyOpted, true, false)}">
                                <h2 class="card-inside-title">Coursera</h2>
                                <div class="row clearfix">
                                    <div class="col-md-12">
                                        <div class="form-group required-label">
                                            <div class="col-md-3 col-sm-12">
                                                <div class="radio">
                                                    <strong>Opt for Coursera <span style="color:red;font-style:bold" >*</span></strong>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-sm-12">
                                                <div class="form-check">
                                                    <input type="radio" name="CourseraPackage" id="CourseraPackagePackage1"
                                                        class="form-check-input with-gap iCheckRadio" data-mode="1" value="true" /><label for="CourseraPackagePackage1">Yes</label>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-sm-12">
                                                <div class="form-check">
                                                    <input type="radio" name="CourseraPackage" id="CourseraPackagePackage2"
                                                        class="form-check-input with-gap iCheckRadio" data-mode="2" value="false" /><label for="CourseraPackagePackage2">No</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </apex:outputPanel>

                            <apex:outputPanel layout="none" rendered="{!IF(((feePaidSem < 3 || strRegFor <=3) && NOT(CONTAINS(objAccount.Batch__c,'_OFFline_')) && (objAccount.Program_Type__c!='M.Sc.' && objAccount.Program_Type__c!='Professional Diploma' && objAccount.Program_Type__c!='BBA' && objAccount.Program_Type__c!='BCom') || 
                                    ( NOT(CONTAINS(objAccount.Batch__c, '_OFFline_')) &&  (( objAccount.Program_Type__c=='BBA' || objAccount.Program_Type__c=='BA') && strRegFor <=3) )),true,false)}">  
                                <h2 class="card-inside-title">Want to change program</h2>
                                <div class="row">
                                    <div class="col-md-12 leftPadding">
                                        <div class="form-group required-label">
                                            <div class="col-md-3 col-sm-12">
                                                <div class="radio">
                                                    <strong>Select an Option <span style="color:red;font-style:bold">*</span></strong>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-sm-12">
                                                <div class="form-check">
                                                    <input type="radio" name="ChangeProg" id="ChangeProg1" class="form-check-input with-gap iCheckRadio"
                                                        data-mode="1" value="Yes" />
                                                    <label for="ChangeProg1">Yes</label>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-sm-12">
                                                <div class="form-check">
                                                    <input type="radio" name="ChangeProg" id="ChangeProg2" class="form-check-input with-gap iCheckRadio"
                                                        data-mode="2" value="No" />
                                                    <label for="ChangeProg2">No</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="ProgramChangePanel" style="display:none;">
                                        <!-- <apex:actionRegion > -->
                                            <apex:pageMessages id="ProgramChangeMessage" />
                                            <apex:inputHidden id="hdnCngProg" value="{!changeProgram}" />
                                            <apex:inputHidden id="hdnChooseProgram" value="{!chooseProgram}" />
                                            <apex:outputPanel styleClass="col-md-12" layout="block" rendered="{!checkProgramSwitch}">
                                                <apex:actionFunction name="ChooseProgramChangeProgramDetails" action="{!getProgramDetails}" reRender="ProgramDetails,editablePanel,ErrorPopUpPanel"
                                                    oncomplete="openPopUp();" />
                                                <apex:actionFunction name="CallValidate" action="{!callValidate}" reRender="academicValidation,editablePanel,ErrorPopUpPanel"
                                                    oncomplete="openPopUp();" />
                                                <div class="form-group">
                                                    <label style="margin-left: 15px;">Choose a Program <span style="color:red;font-style:bold">*</span></label>
                                                    <div class="row">
                                                        <apex:outputPanel styleClass="col-md-3 col-sm-12 leftPadding" layout="block" rendered="{!objAvialableProgram.diploma}" >
                                                            <div class="form-check">
                                                                <input type="radio" value="Diploma Programs" name="programRadio" id="DiplomaPrograms" data-mode="2" class="form-check-input with-gap iCheckRadio" />
                                                                <label for="DiplomaPrograms"> Diploma Programs </label>  
                                                            </div>                                                      
                                                        </apex:outputPanel>
