 <script>
  $(document).ready(function (e) { 
        $('body').on('focus','.form-control', function(){
            $(this).closest('.form-line').addClass('focused');
        });
      });

    function showHtmlMessage(header,message) {
        if(/<\/?[a-z][\s\S]*>/i.test(message)) {
            swal({
                title: header+"!",
                html: message,
                type: "warning"
            });
        } else {
            swal({
                title: header+"!",
                text: message,
                type: "warning"
            });
        }
    }
function closeModal(){
  
   document.getElementById('emailverifybtn').classList.remove('disabled');
   document.getElementById('mobileverifybtn').classList.remove('disabled');
}
function showemailmobileform(){
  const selectedOption = document.getElementById('{!$Component.selectedOptionId}').value;
  const mobilePanel = document.getElementById('{!$Component.mobilepanelId}');
  const emailPanel = document.getElementById('{!$Component.emailpanelId}');
  document.getElementById('{!$Component.emailfieldId}').value = '';
  document.getElementById('{!$Component.mobilefieldId}').value = '';
  console.log('selectedOptionId',document.getElementById('{!$Component.selectedOptionId}').value);
  if(selectedOption === 'Email'){
    mobilePanel.style.display = 'none';
    emailPanel.style.display = 'block';
  } else if(selectedOption === 'Mobile'){
    mobilePanel.style.display = 'block';
    emailPanel.style.display = 'none';
  } else{
    mobilePanel.style.display = 'none';
    emailPanel.style.display = 'none';
  }
}
  function getTimmer(){
    const timerDisplay = document.getElementById('timer'); 
    let totalSeconds = 3 * 60; //3sec
    function updateTimer() {
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        const formattedSeconds = seconds < 10 ? '0' + seconds : seconds;
        timerDisplay.textContent = `${minutes}:${formattedSeconds}`;
        if (totalSeconds <= 0) {
            clearInterval(timerInterval);
          //  timerDisplay.textContent = "Time's up!";
            //document.getElementById('resendBtn').disabled = false;;
            document.getElementById('resendBtn').classList.remove('disabled');
            //timerDisplay.textContent = `${minutes}`;
        } else {
            totalSeconds--;
            //document.getElementById('resendBtn').style.display = 'none';
        }
       
    }
    const timerInterval = setInterval(updateTimer, 1000);
  }


function triggerOTP() {
    document.getElementById('resendBtn').classList.add('disabled');
    document.getElementById('{!$Component.otpInputId}').value = '';
    SendOTP();
    return true;
}

function showModalMsg(message) {
          let element = document.getElementById('errorMsgId');
          if (element) {
              element.innerText = message; // Set the message text

              // Show the element
              element.style.display = 'block';

              // Hide it after 9 seconds
              setTimeout(() => {
                  element.style.display = 'none';
              }, 9000);
          } else {
              console.error('Element not found: errorMsgId');
          }
        }
function validateOTPInput() {
            let otpInput = document.getElementById('{!$Component.otpInputId}').value;
            console.log('otpInput',typeof(otpInput));
            if(otpInput == '' || otpInput.length == 0 || otpInput == null) {
                showModalMsg('Please enter the value');
                return false;
            }
            VerifyOTP(otpInput);
            //return true;
        }

     function validateInput() {
      console.log('validation');
      let selectedOptionvalue = document.getElementById('{!$Component.selectedOptionId}').value;
      let isValid = false;
      if(selectedOptionvalue === 'Email'){
      let inputValue = document.getElementById('{!$Component.emailfieldId}').value;
      const emailRegex = /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
      isValid = emailRegex.test(String(inputValue).toLowerCase());

      if('{!objRecord.email}' === String(inputValue)){
          isValid = false;
        if (!isValid) {
          showHtmlMessage("Validation error","New email cannot be the same as the current email!");
          return false;
        }
      }
  
      if (!isValid) {
        showHtmlMessage("Validation error","Please enter valid email Id!");
        return false;
      }
      document.getElementById('emailverifybtn').classList.add('disabled');
      }
      else if(selectedOptionvalue === 'Mobile'){
        let inputValue = document.getElementById('{!$Component.mobilefieldId}').value;
        const mobileRegex = /^[0-9]{10}$/;
        isValid = mobileRegex.test(String(inputValue).toLowerCase());
        if('{!objRecord.phone}' === String(inputValue.trim())){
          isValid = false;
          if (!isValid) {
          showHtmlMessage("Validation error","New mobile no cannot be the same as the current mobile no!");
          return false;
        }
        }
        if (!isValid) {
          //alert("Invalid data!");
          showHtmlMessage("Validation error","Please enter valid mobile no!");
          return false;
        }
        document.getElementById('mobileverifybtn').classList.add('disabled');
      }
    
    if (!isValid) {
      //alert("Invalid data!");
      showHtmlMessage("Validation error","Invalid data!");
      return false;
    }
      doUpdatefield();
      return true;
     }
</script>

</apex:component>