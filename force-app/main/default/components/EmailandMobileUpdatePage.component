  <apex:actionFunction name="doUpdatefield" action="{!doUpdatefield}" reRender="handleMsg,otpInput,errorMsg,VerificationModal,dupMessageId,showVerificationModalId" oncomplete="showVerificationModal();">
  </apex:actionFunction>
  <apex:actionFunction name="VerifyOTP" action="{!VerifyOTP}" reRender="handleMsg,otpInput,errorMsg,currentEmailId,currentMobileNoId" oncomplete="showErrorMsg();">
      <apex:param name="otpCode" value="" assignTo="{!objOTP.Otp}" />
  </apex:actionFunction>
  <apex:outputPanel styleClass="modal  VerificationModal" id="VerificationModal" html-tabindex="-1" html-role="dialog" layout="block">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
          <div class="modal-header">
            <h4 class="modal-title" id="defaultModalLabel">OTP Verification!</h4>
          </div>
          <div class="modal-body row">
            <apex:outputPanel id="errorMsg" rendered="{! !objOTP.isSuccess}" >
              <p class="errorMsg" id="errorMsgId" style="color:red;">{!objOTP.errorMsg}</p> 
            </apex:outputPanel>
            <p>Enter the code sent to your {!objOTP.alertMsg} to verify your account.</p>
            <apex:inputText id="otpInputId"  styleClass="form-control numonly notnull" value="{!objOTP.Otp}" html-placeholder="Enter OTP.." />
          </div>
          <div class="modal-footer">
            <a href="javascript:void(0);" id="resendBtn" class="btn btn-lg btn-primary waves-effect disabled" onclick="return triggerOTP();" style="display : inline;">Resend<span class="timerSection noTop">(<span class="showTimer noTop"></span><span Id="timer" style="top: 0px;"></span>)</span></a>
            <a href="javascript:void(0);" class="btn btn-lg btn-primary waves-effect" onclick="return validateOTPInput();">Submit</a>
            <a href="javascript:void(0);" class="btn btn-lg btn-primary waves-effect" data-dismiss="modal" onclick=" closeModal();" id="closeId" >Close</a>
          </div>
      </div>
    </div>
  </apex:outputPanel>
  <apex:actionFunction name="SendOTP" action="{!sendOTP}" reRender="VerificationModal,handleMsg" oncomplete="showVerificationModal();">
  </apex:actionFunction>
